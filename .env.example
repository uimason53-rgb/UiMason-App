NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Required in production. Development can run without this, but setting it keeps
# local tokens stable across restarts.
JWT_SECRET=replace-with-a-long-random-secret

# AI provider keys. Set only the providers you want to use.
OPENAI_KEY=
DEEPSEEK_KEY=
CLAUDE_KEY=
GEMINI_KEY=

# Deployment providers.
VERCEL_TOKEN=
VERCEL_TEAM_ID=
NETLIFY_TOKEN=
NETLIFY_SITE_ID=
